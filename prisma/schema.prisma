generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model Pillar {
  id          Int      @id
  name        String
  description String
  colorHex    String
  textHex     String
  intent      String   @db.Text
  tasks       Task[]
  reviews     Review[]
  hooks       Hook[]
  mediaAssets MediaAsset[]
  ideas       Idea[]
}

model Week {
  id          String   @id @default(cuid())
  weekStart   DateTime @unique
  status      String   @default("active")
  tasks       Task[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Task {
  id          String      @id @default(cuid())
  week        Week        @relation(fields: [weekId], references: [id], onDelete: Cascade)
  weekId      String
  dayOfWeek   Int
  type        TaskType
  pillar      Pillar?     @relation(fields: [pillarId], references: [id])
  pillarId    Int?
  title       String
  detail      String      @db.Text
  brief       String      @db.Text
  done         Boolean     @default(false)
  skipped      Boolean     @default(false)
  doneAt       DateTime?
  order        Int         @default(0)
  recipeId     String?
  parentTaskId String?
  parent       Task?       @relation("TaskDeps", fields: [parentTaskId], references: [id], onDelete: SetNull)
  children     Task[]      @relation("TaskDeps")
  ideaId       String?
  idea         Idea?       @relation(fields: [ideaId], references: [id], onDelete: SetNull)
  mediaAssets  MediaAsset[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([weekId, dayOfWeek])
}

enum TaskType {
  film
  edit
  post
  prep
  engage
}

model MediaAsset {
  id            String       @id @default(cuid())
  filename      String
  mimeType      String
  sizeBytes    Int
  r2Key         String
  publicUrl     String
  thumbnailUrl  String?
  task          Task?        @relation(fields: [taskId], references: [id])
  taskId        String?
  pillar        Pillar?      @relation(fields: [pillarId], references: [id])
  pillarId      Int?
  status        MediaStatus  @default(draft)
  scriptText    String?      @db.Text
  notes         String?      @db.Text
  aiReview      String?      @db.Text
  aiScore       Int?
  aiReviewedAt  DateTime?
  postedAt      DateTime?
  instagramPostId String?   @unique
  performance   Performance?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([status])
  @@index([taskId])
}

enum MediaStatus {
  draft
  claude_reviewed
  approved
  posted
  archived
}

model Review {
  id               String   @id
  rating           Int
  email            String?
  nickname         String?
  fullName         String?
  reviewText       String   @db.Text
  reviewDate       DateTime
  imageUrl         String?
  verifiedPurchase Boolean  @default(false)
  duration         String?
  themes           String[]
  pillar           Pillar?  @relation(fields: [pillarId], references: [id])
  pillarId         Int?
  contentPotential Int      @default(0)
  usedInContent    Boolean  @default(false)
  ugcRequested     Boolean  @default(false)
  ugcReceived      Boolean  @default(false)
  hooks            Hook[]
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([rating])
  @@index([pillarId])
}

model Hook {
  id          String   @id @default(cuid())
  text        String   @db.Text
  source      String
  review      Review?  @relation(fields: [reviewId], references: [id])
  reviewId    String?
  pillar      Pillar   @relation(fields: [pillarId], references: [id])
  pillarId    Int
  tags        String[]
  timesUsed   Int      @default(0)
  performance Float?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([pillarId])
}

enum IdeaStatus {
  raw
  processed
  planned
  filmed
  archived
}

model Idea {
  id             String     @id @default(cuid())
  rawDump        String     @db.Text
  title          String     @default("")
  pillarId       Int?
  pillar         Pillar?    @relation(fields: [pillarId], references: [id])
  contentType    String     @default("reel")
  status         IdeaStatus @default(raw)
  hook           String?    @db.Text
  hookVariants   String[]
  framework      String?    @db.Text
  shootChecklist String[]
  caption        String?    @db.Text
  priority       Int        @default(0)
  tags           String[]
  reasoning      String?    @db.Text
  tasks          Task[]
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@index([status])
  @@index([pillarId])
}

model Performance {
  id              String     @id @default(cuid())
  mediaAsset      MediaAsset @relation(fields: [mediaAssetId], references: [id], onDelete: Cascade)
  mediaAssetId    String     @unique
  platform        String
  views           Int?
  likes           Int?
  comments        Int?
  shares          Int?
  saves           Int?
  reach           Int?
  retention3s     Float?
  watchTimeAvg    Float?
  skipRate        Float?
  follows         Int?
  link_clicks     Int?
  notes           String?    @db.Text
  loggedAt        DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
}
